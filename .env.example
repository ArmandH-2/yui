# ═══════════════════════════════════════════
# Yui — Autonomous Minecraft Staff Manager
# ═══════════════════════════════════════════

# Discord
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_PREFIX=!
DISCORD_CHANNEL_ID=your_discord_channel_id_here
OWNER_DISCORD_ID=your_discord_user_id,another_user_id
OWNER_NAME=YourName

# Minecraft Server (Cracked)
MC_HOST=localhost
MC_PORT=25565
MC_USERNAME=YuiBot
MC_VERSION=1.20.1
MC_LOGIN_COMMAND=/login password password

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ChromaDB (optional — falls back to local JSON store)
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=yui_memories

# Logging
LOG_LEVEL=info
